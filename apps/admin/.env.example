# ── API ─────────────────────────────────────────────────────────────────────
# Base URL of the DrivenRewards API (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# ── App ─────────────────────────────────────────────────────────────────────
# Public URL of the admin panel
NEXT_PUBLIC_APP_URL=http://localhost:3002

# ── Google Maps ─────────────────────────────────────────────────────────────
# Google Maps JS API key for partner/heatmap views
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── Auth ────────────────────────────────────────────────────────────────────
# Cookie name for storing refresh token
REFRESH_TOKEN_COOKIE=dr_admin_refresh_token

# ── Server-only ─────────────────────────────────────────────────────────────
# Internal API URL for Next.js server components / API routes
API_URL=http://localhost:3001/api/v1
