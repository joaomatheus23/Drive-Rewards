# ── API ─────────────────────────────────────────────────────────────────────
# Base URL of the DrivenRewards API (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# ── App ─────────────────────────────────────────────────────────────────────
# Public URL of the partner portal (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stripe ──────────────────────────────────────────────────────────────────
# Stripe publishable key (pk_test_... for dev)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ── Google Maps ─────────────────────────────────────────────────────────────
# Google Maps JS API key for partner location picker
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── Auth ────────────────────────────────────────────────────────────────────
# Cookie name for storing refresh token (httpOnly set server-side)
REFRESH_TOKEN_COOKIE=dr_refresh_token

# ── Server-only (not exposed to browser) ────────────────────────────────────
# Used by Next.js API routes if needed for server-side calls
API_URL=http://localhost:3001/api/v1
