# ── API ─────────────────────────────────────────────────────────────────────
# Base URL — use localhost no simulador; no iPhone físico o app detecta o IP automaticamente
EXPO_PUBLIC_API_URL=http://localhost:3050/api/v1

# ── Google Maps ─────────────────────────────────────────────────────────────
# Google Maps SDK key for map display in the driver app
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── Firebase / FCM ──────────────────────────────────────────────────────────
# Firebase project ID (from Firebase console)
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase API key (public, restricted by bundle ID in Firebase console)
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key

# Firebase messaging sender ID
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# Firebase app ID
EXPO_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# ── Location / GPS ──────────────────────────────────────────────────────────
# Background location task name (must match app.json task definition)
EXPO_PUBLIC_LOCATION_TASK_NAME=BACKGROUND_LOCATION_TASK

# GPS sampling interval in milliseconds while driving
EXPO_PUBLIC_GPS_INTERVAL_MS=10000

# ── App Config ──────────────────────────────────────────────────────────────
# App environment label shown in dev builds
EXPO_PUBLIC_APP_ENV=development
